{
  "name": "server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test",
    "test:boundary": "node --import tsx --test test/boundary.test.ts",
    "seed:admin": "tsx src/scripts/seed-admin.ts",
    "seed:ai": "tsx src/scripts/seed-ai.ts",
    "keygen": "tsx src/scripts/keygen.ts",
    "rotate-key": "tsx src/scripts/rotate-key.ts",
    "aes-roundtrip": "tsx src/scripts/aes-roundtrip.ts",
    "regenerate-fingerprints": "tsx src/scripts/regenerate-fingerprints.ts",
    "cleanup": "tsx src/scripts/cleanup-action-logs.ts",
    "migrate": "node-pg-migrate up -m migrations",
    "migrate:create": "node-pg-migrate create -m migrations"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "8.0.1",
    "@fastify/multipart": "^8.3.1",
    "@fastify/websocket": "^8.3.1",
    "@types/node-cron": "^3.0.11",
    "adm-zip": "^0.5.17",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.7",
    "fastify": "^4.29.1",
    "node-cron": "^3.0.3",
    "pg": "^8.13.1",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.17.10",
    "@types/pg": "^8.11.10",
    "@types/uuid": "^10.0.0",
    "node-pg-migrate": "^7.7.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "overrides": {
    "fast-jwt": "6.2.4",
    "fast-uri": "3.1.2"
  }
}
